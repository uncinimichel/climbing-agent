prototypes/

# Trip-independent weather/tide cache: produced by fetch_env.py and consumed by
# update_report.py within the same daily run. Heavy (raw hourly × all venues) and
# fully re-churned every day, so it's kept out of git history (decision #24). The
# report degrades to live fetches when it's absent.
cache/venue-env.json

# Raw crawl captures (roadmap Stage 5) — the crawler's local raw store, never
# committed to the public repo (theCrag/UKC raw data stays private per agreement).
db/.raw_cache/

# Secrets — NEVER commit (this repo is public). Keys go in GitHub Actions secrets.
.env
.env.*
*.secret
secrets.json
credentials*.json
agent/.venv/
