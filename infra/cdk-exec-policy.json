{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "RdsAndNetworking",
      "Effect": "Allow",
      "Action": [
        "rds:*",
        "ec2:CreateSecurityGroup",
        "ec2:DeleteSecurityGroup",
        "ec2:AuthorizeSecurityGroupIngress",
        "ec2:AuthorizeSecurityGroupEgress",
        "ec2:RevokeSecurityGroupIngress",
        "ec2:RevokeSecurityGroupEgress",
        "ec2:CreateTags",
        "ec2:DeleteTags",
        "ec2:Describe*"
      ],
      "Resource": "*"
    },
    {
      "Sid": "OnlyOurSecrets",
      "Effect": "Allow",
      "Action": [
        "secretsmanager:*"
      ],
      "Resource": "arn:aws:secretsmanager:eu-west-2:166832185275:secret:climbing-agent/*"
    },
    {
      "Sid": "DefaultKeyGrantsForEncryptedStorage",
      "Effect": "Allow",
      "Action": [
        "kms:DescribeKey",
        "kms:CreateGrant",
        "kms:Decrypt",
        "kms:GenerateDataKey"
      ],
      "Resource": "*"
    },
    {
      "Sid": "ReadDeployAssets",
      "Effect": "Allow",
      "Action": [
        "s3:GetObject*",
        "s3:GetBucket*",
        "s3:List*"
      ],
      "Resource": "*"
    },
    {
      "Sid": "CdkBootstrapVersionCheckOnly",
      "Effect": "Allow",
      "Action": [
        "ssm:GetParameter",
        "ssm:GetParameters"
      ],
      "Resource": "arn:aws:ssm:eu-west-2:166832185275:parameter/cdk-bootstrap/*"
    },
    {
      "Sid": "StudioStackServices",
      "Effect": "Allow",
      "Action": [
        "cognito-idp:*",
        "lambda:*",
        "apigateway:*",
        "cloudfront:*",
        "logs:*",
        "s3:CreateBucket",
        "s3:DeleteBucket",
        "s3:PutBucket*",
        "s3:DeleteObject",
        "s3:PutObject"
      ],
      "Resource": "*"
    },
    {
      "Sid": "LambdaRolesOnly",
      "Effect": "Allow",
      "Action": [
        "iam:CreateRole",
        "iam:DeleteRole",
        "iam:AttachRolePolicy",
        "iam:DetachRolePolicy",
        "iam:PutRolePolicy",
        "iam:DeleteRolePolicy",
        "iam:GetRole",
        "iam:PassRole",
        "iam:TagRole",
        "iam:UntagRole",
        "iam:ListRolePolicies",
        "iam:GetRolePolicy"
      ],
      "Resource": "arn:aws:iam::166832185275:role/ClimbingAgentStudio*"
    }
  ]
}
